Include ~/.orbstack/ssh/config

Host github.com
  AddKeysToAgent yes
  # Omit if no passphrase
  UseKeychain yes
  IdentitiesOnly yes
  IdentityFile ~/.ssh/github
  # Hostname ssh.github.com
  # Port 443
  # User git

Host ssh.satorinet-pools.com
  User root
  PasswordAuthentication no
  IdentityFile ~/.ssh/id_satorinet_pools

Host home.etienne-blanc.com
  AddKeysToAgent yes
  User user
  Port 222
  # Omit if no passphrase
  # UseKeychain yes
  IdentitiesOnly yes
  IdentityFile ~/.ssh/id_server_mac_etienne
