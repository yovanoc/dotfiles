{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "auto_update": true,
  "agents": {
    "sisyphus": {
      "model": "kimi-for-coding/k2p6",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/deepseek-v4-pro",
        "opencode-go/qwen3.6-plus"
      ],
      "ultrawork": {
        "model": "github-copilot/claude-opus-4.7",
        "variant": "max"
      },
      "prompt_append": "Delegate heavily to hephaestus for implementation. Parallelize exploration."
    },
    "sisyphus-junior": {
      "model": "opencode/gpt-5-nano",
      "fallback_models": [
        "github-copilot/gpt-5-mini",
        "opencode-go/deepseek-v4-flash"
      ]
    },
    "prometheus": {
      "model": "github-copilot/claude-opus-4.7",
      "variant": "max",
      "thinking": {
        "type": "enabled"
      },
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "opencode-go/glm-5.1",
        "opencode-go/qwen3.6-plus",
        "opencode-go/deepseek-v4-pro"
      ],
      "prompt_append": "Always interview first. Validate scope before planning."
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "opencode/gpt-5.3-codex",
        "opencode-go/deepseek-v4-pro",
        "opencode-go/deepseek-v4-flash",
        "kimi-for-coding/k2p6",
        "opencode-go/kimi-k2.6"
      ],
      "permission": {
        "edit": "allow",
        "bash": {
          "git": "allow",
          "test": "allow"
        }
      },
      "prompt_append": "You are the primary implementation agent. Explore thoroughly, then implement. Prefer small, testable changes. Use LSP and AST-grep aggressively."
    },
    "metis": {
      "model": "github-copilot/claude-opus-4.7",
      "fallback_models": [
        "openai/gpt-5.5",
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.6-plus",
        "opencode-go/deepseek-v4-pro"
      ],
      "prompt_append": "Critically evaluate plans. Identify gaps, risks, and improvements."
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "fallback_models": [
        "github-copilot/gpt-5.4",
        "opencode/gpt-5.4",
        "kimi-for-coding/k2p6",
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.6-plus"
      ],
      "prompt_append": "Focus on code quality, edge cases, and test coverage. Challenge assumptions."
    },
    "atlas": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/qwen3.6-plus",
        "opencode-go/deepseek-v4-flash"
      ],
      "prompt_append": "Preserve context across long sessions. Track evolving decisions."
    },
    "librarian": {
      "model": "github-copilot/grok-code-fast-1",
      "fallback_models": [
        // "opencode/gpt-5-nano",
        "opencode-go/deepseek-v4-flash",
        "opencode-go/qwen3.5-plus"
      ]
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1", // ???
      "fallback_models": [
        "opencode-go/deepseek-v4-flash"
      ]
    },
    "oracle": {
      "variant": "high",
      "model": "openai/gpt-5.5",
      "fallback_models": [
        "github-copilot/gpt-5.4",
        "zai-coding-plan/glm-5.1",
        "kimi-for-coding/k2p6",
        "opencode/gpt-5.4",
        "opencode-go/glm-5.1",
        "opencode-go/kimi-k2.6",
        "opencode-go/deepseek-v4-pro"
      ]
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      // "variant": "high",
      "fallback_models": [
        // "opencode/gemini-3.1-pro",
        "opencode-go/mimo-v2-omni",
        "opencode-go/qwen3.6-plus"
      ]
    }
  },
  "categories": {
    "quick": {
      "model": "github-copilot/claude-haiku-4.5",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-go/qwen3.5-plus"
      ]
    },
    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/qwen3.6-plus",
        "opencode-go/deepseek-v4-flash"
      ]
    },
    "unspecified-high": {
      "model": "github-copilot/claude-opus-4.7",
      "variant": "max",
      "fallback_models": [
        "openai/gpt-5.5",
        "github-copilot/gpt-5.3-codex",
        "opencode/gpt-5.3-codex",
        "opencode-go/deepseek-v4-pro",
        "kimi-for-coding/k2p6",
        "opencode-go/kimi-k2.6"
      ]
    },
    "writing": {
      "model": "github-copilot/gpt-5-mini",
      "fallback_models": [
        "opencode/gpt-5-nano",
        "opencode-go/qwen3.6-plus",
        "opencode-go/deepseek-v4-pro"
      ]
    },
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "opencode/gemini-3.1-pro",
        "opencode-go/mimo-v2-omni",
        "opencode-go/qwen3.6-plus"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "opencode/gpt-5.3-codex",
        "opencode-go/kimi-k2.6",
        "kimi-for-coding/k2p6",
        "opencode-go/deepseek-v4-pro"
      ]
    },
    "ultrabrain": {
      "variant": "xhigh",
      "model": "openai/gpt-5.5",
      "fallback_models": [
        "github-copilot/gpt-5.4",
        "opencode/gpt-5.4",
        "zai-coding-plan/glm-5.1",
        "kimi-for-coding/k2p6",
        "opencode-go/glm-5.1"
      ]
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "opencode/gemini-3.1-pro",
        "opencode-go/mimo-v2-omni"
      ]
    },
    "git": {
      "model": "github-copilot/claude-haiku-4.5",
      "fallback_models": [
        "github-copilot/gpt-5-mini",
        "opencode/gpt-5-nano",
        "opencode-go/deepseek-v4-flash"
      ],
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations."
    }
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "openai": 2,
      "opencode": 3,
      "github-copilot": 4,
      "kimi-for-coding": 4,
      "zai-coding-plan": 6,
      "opencode-go": 10
    },
    "modelConcurrency": {
      "github-copilot/claude-opus-4.7": 1,
      "openai/gpt-5.5": 1,
      "opencode-go/kimi-k2.6": 2,
      "opencode-go/deepseek-v4-pro": 3,
      "opencode-go/deepseek-v4-flash": 20,
      "opencode-go/qwen3.5-plus": 15,
      "opencode-go/glm-5.1": 1,
      "opencode-go/qwen3.6-plus": 5,
      "opencode-go/mimo-v2-omni": 2
    }
  },
  "hashline_edit": true,
  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      401,
      402,
      403,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "model_capabilities": {
    "enabled": true,
    "auto_refresh_on_start": true,
    "refresh_timeout_ms": 5000
  },
  "team_mode": {
    "enabled": true,
    "tmux_visualization": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "max_messages_per_run": 10000,
    "max_wall_clock_minutes": 120,
    "max_member_turns": 500,
    "message_payload_max_bytes": 32768,
    "recipient_unread_max_bytes": 262144,
    "mailbox_poll_interval_ms": 3000
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true,
    "auto_resume": false,
    "preemptive_compaction": false,
    "truncate_all_tool_outputs": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "detailed",
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "rtk_read",
        "rtk_write",
        "rtk_grep",
        "rtk_glob",
        "cachebro_read_file",
        "cachebro_read_files"
      ],
      "strategies": {},
      "turn_protection": {
        "enabled": true,
        "turns": 1
      }
    }
  },
  "sisyphus_agent": {
    "disabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "inline"
  },
  "notification": {
    "force_enable": true
  }
}
