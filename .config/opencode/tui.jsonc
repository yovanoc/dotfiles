{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "tokyonight",
  "keybinds": {
    "leader": "ctrl+x",
  },
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true,
  },
  "diff_style": "auto",
  "attention": {
    "enabled": true,
    "notifications": true,
    "sound": true,
    "volume": 1,
  }
}
